<style>
  :root{
    --ink:#0B1F38; --navy:#0F2A47; --teal:#0F9E8C; --teal-bright:#2DD4BF;
    --paper:#FFFFFF; --mist:#F2F6F9; --line:#E2E8F0; --muted:#5B6B7F; --text:#1E2A38;
    --maxw:1240px;
    --display:'Space Grotesk',system-ui,sans-serif;
    --body:'IBM Plex Sans',system-ui,sans-serif;
    --mono:'IBM Plex Mono',ui-monospace,monospace;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:var(--body);color:var(--text);background:var(--paper);line-height:1.65;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px}
  .eyebrow{font-family:var(--mono);font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;color:var(--teal);font-weight:500}
  .eyebrow::before{content:"// ";opacity:.55}

  /* NAV */
  nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.86);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;height:64px;max-width:var(--maxw);margin:0 auto;padding:0 28px}
  .monogram{font-family:var(--display);font-weight:700;font-size:1.05rem;letter-spacing:-.01em;color:var(--ink);display:flex;align-items:center;gap:9px}
  .monogram .dot{width:9px;height:9px;border-radius:2px;background:var(--teal-bright);box-shadow:0 0 0 3px rgba(45,212,191,.18)}
  .nav-links{display:flex;gap:28px;font-size:.9rem;font-weight:500}
  .nav-links a{color:var(--muted);transition:color .18s}
  .nav-links a:hover{color:var(--ink)}
  .nav-toggle{display:none;background:none;border:0;cursor:pointer;padding:6px}
  .nav-toggle span{display:block;width:22px;height:2px;background:var(--ink);margin:4px 0}

  /* HERO */
  header{padding:86px 0 70px;position:relative;overflow:hidden}
  .hero-grid{display:grid;grid-template-columns:1fr;gap:0;max-width:780px}
  .avatar{width:96px;height:96px;border-radius:50%;margin-bottom:22px;position:relative;box-shadow:0 0 0 4px #fff,0 0 0 6px var(--teal-bright),0 16px 32px -14px rgba(11,31,56,.45)}
  .avatar img{width:100%;height:100%;object-fit:cover;border-radius:50%;display:block}
  .avatar-fallback{display:none;position:absolute;inset:0;border-radius:50%;align-items:center;justify-content:center;background:var(--navy);color:#fff;font-family:var(--display);font-weight:700;font-size:2rem;letter-spacing:.02em}
  .status{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:.72rem;letter-spacing:.06em;color:var(--muted);background:var(--mist);border:1px solid var(--line);padding:6px 12px;border-radius:999px;margin-bottom:22px}
  .status .pulse{width:7px;height:7px;border-radius:50%;background:var(--teal);box-shadow:0 0 0 0 rgba(15,158,140,.5);animation:pulse 2.4s infinite}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(15,158,140,.45)}70%{box-shadow:0 0 0 8px rgba(15,158,140,0)}100%{box-shadow:0 0 0 0 rgba(15,158,140,0)}}
  h1{font-family:var(--display);font-weight:700;letter-spacing:-.02em;font-size:clamp(2.4rem,5.4vw,3.7rem);line-height:1.04;color:var(--ink)}
  h1 .accent{color:var(--teal)}
  .lede{margin-top:20px;font-size:1.12rem;color:var(--muted);max-width:34ch}
  .lede strong{color:var(--text);font-weight:600}
  .cta-row{margin-top:32px;display:flex;flex-wrap:wrap;gap:12px}
  .btn{font-family:var(--body);font-weight:600;font-size:.92rem;padding:12px 20px;border-radius:10px;border:1px solid var(--line);transition:all .18s;cursor:pointer;display:inline-flex;align-items:center;gap:8px}
  .btn-solid{background:var(--ink);color:#fff;border-color:var(--ink)}
  .btn-solid:hover{background:var(--teal);border-color:var(--teal)}
  .btn-ghost:hover{border-color:var(--ink);background:var(--mist)}

  .ledger{background:var(--navy);color:#fff;border-radius:16px;padding:26px 26px 22px;box-shadow:0 24px 60px -28px rgba(11,31,56,.55);position:relative}
  .ledger::before{content:"";position:absolute;inset:0;border-radius:16px;border-top:4px solid var(--teal-bright)}
  .ledger h3{font-family:var(--mono);font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--teal-bright);font-weight:500;margin-bottom:14px}
  .ledger-row{display:flex;justify-content:space-between;align-items:baseline;padding:11px 0;border-bottom:1px dashed rgba(255,255,255,.16);gap:14px}
  .ledger-row:last-child{border-bottom:0}
  .ledger-row .k{font-size:.82rem;color:#9DB2C9}
  .ledger-row .v{font-family:var(--mono);font-size:.82rem;color:#fff;text-align:right}

  /* SECTIONS */
  section{padding:70px 0;border-top:1px solid var(--line)}
  .sec-head{margin-bottom:38px;max-width:62ch}
  .sec-head h2{font-family:var(--display);font-weight:600;letter-spacing:-.01em;font-size:clamp(1.6rem,3.4vw,2.15rem);color:var(--ink);margin-top:10px;line-height:1.12}
  .about-body{font-size:1.08rem;color:var(--text);max-width:64ch}
  .about-body p+p{margin-top:18px}

  .exp-grid{display:grid;grid-template-columns:1fr 1fr;gap:26px}
  .card{background:var(--mist);border:1px solid var(--line);border-radius:14px;padding:26px}
  .card h3{font-family:var(--display);font-size:1.12rem;color:var(--ink);margin-bottom:6px;display:flex;align-items:center;gap:10px}
  .card h3 .tag{width:8px;height:18px;border-radius:3px;background:var(--teal)}
  .card .sub{font-size:.86rem;color:var(--muted);margin-bottom:18px}
  .chips{display:flex;flex-wrap:wrap;gap:8px}
  .chip{font-family:var(--mono);font-size:.78rem;background:#fff;border:1px solid var(--line);color:var(--text);padding:6px 11px;border-radius:7px}
  .chip.lead{background:var(--ink);color:#fff;border-color:var(--ink)}
  .strengths{margin-top:24px;font-family:var(--mono);font-size:.82rem;color:var(--muted)}
  .strengths b{color:var(--teal);font-weight:500}

  .timeline{position:relative;margin-left:6px}
  .tl-item{position:relative;padding:0 0 34px 30px;border-left:2px solid var(--line)}
  .tl-item:last-child{padding-bottom:0}
  .tl-item::before{content:"";position:absolute;left:-7px;top:4px;width:12px;height:12px;border-radius:50%;background:#fff;border:3px solid var(--teal)}
  .tl-when{font-family:var(--mono);font-size:.76rem;letter-spacing:.04em;color:var(--teal)}
  .tl-role{font-family:var(--display);font-weight:600;font-size:1.12rem;color:var(--ink);margin:3px 0 2px}
  .tl-org{font-size:.92rem;color:var(--muted);margin-bottom:8px}
  .tl-item ul{margin:0;padding-left:18px;color:var(--text);font-size:.96rem}
  .tl-item li{margin:5px 0}
  .tl-item ul ul{margin-top:5px}

  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
  .edu{border:1px solid var(--line);border-radius:12px;padding:20px 22px}
  .edu .deg{font-family:var(--display);font-weight:600;color:var(--ink);font-size:1.05rem}
  .edu .inst{font-size:.9rem;color:var(--muted);margin-top:3px}
  .edu .yr{font-family:var(--mono);font-size:.78rem;color:var(--teal);margin-top:8px}

  .ach{display:flex;gap:14px;padding:18px 20px;border:1px solid var(--line);border-radius:12px;background:var(--mist)}
  .ach .mk{font-family:var(--mono);color:var(--teal);font-weight:500;flex:none}
  .ach p{font-size:.95rem;margin:0;color:var(--text)}

  /* INVESTING */
  .screen-card{display:grid;grid-template-columns:1.45fr .9fr;gap:30px;align-items:center;background:var(--mist);border:1px solid var(--line);border-radius:16px;padding:32px}
  .screen-name{font-family:var(--display);font-weight:600;font-size:1.3rem;color:var(--ink)}
  .screen-name .badge{font-family:var(--mono);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal);background:#fff;border:1px solid var(--line);border-radius:6px;padding:3px 8px;vertical-align:middle;margin-left:10px}
  .screen-desc{margin:12px 0 22px;color:var(--text);max-width:48ch}
  .screen-aside{background:var(--navy);border-radius:13px;padding:22px}
  .screen-aside h4{font-family:var(--mono);font-size:.64rem;letter-spacing:.14em;text-transform:uppercase;color:var(--teal-bright);margin-bottom:12px}
  .srow{display:flex;justify-content:space-between;align-items:baseline;padding:8px 0;border-bottom:1px dashed rgba(255,255,255,.16);gap:12px}
  .srow:last-child{border-bottom:0}
  .srow .k{font-size:.82rem;color:#9DB2C9}
  .srow .v{font-family:var(--mono);font-size:.82rem;color:#fff}

  /* {CODE.NULL} TERMINAL */
  .terminal{background:#0A1A2F;border:1px solid #1C3A5C;border-radius:14px;overflow:hidden;box-shadow:0 24px 60px -28px rgba(11,31,56,.55);max-width:700px}
  .term-bar{display:flex;align-items:center;gap:8px;padding:12px 16px;background:#0F2A47;border-bottom:1px solid #1C3A5C}
  .term-bar .d{width:11px;height:11px;border-radius:50%}
  .term-bar .r{background:#FF5F56}.term-bar .y{background:#FFBD2E}.term-bar .g{background:#27C93F}
  .term-bar .ttl{margin-left:8px;font-family:var(--mono);font-size:.74rem;color:#7C90A8}
  .term-body{padding:24px 22px 28px;font-family:var(--mono);font-size:.88rem;line-height:2;color:#CDE3F0}
  .term-body .pr{color:var(--teal-bright)}
  .term-body .ok{color:#27C93F}
  .term-body .wait{color:#FFBD2E}
  .term-body .key{color:#fff;font-weight:500}
  .term-body .soon{color:var(--teal-bright);font-weight:600;letter-spacing:.08em}
  .term-body .build{color:#FFBD2E;font-weight:600;letter-spacing:.06em}
  .term-body .fill{color:var(--teal-bright);letter-spacing:1px}
  .term-body .dim{color:#34547A;letter-spacing:1px}
  .cursor{display:inline-block;width:9px;height:1.05em;background:var(--teal-bright);vertical-align:-2px;margin-left:4px;animation:blink 1.1s steps(1) infinite}
  @keyframes blink{50%{opacity:0}}

  /* CONTACT */
  .contact{background:var(--ink);color:#fff;border-radius:18px;padding:46px 40px;display:grid;grid-template-columns:1fr 1fr;gap:44px}
  .contact .eyebrow{color:var(--teal-bright)}
  .contact h2{font-family:var(--display);font-weight:600;font-size:clamp(1.5rem,3vw,2rem);color:#fff;max-width:18ch;line-height:1.12;margin-top:10px}
  .contact .intro{color:#9DB2C9;margin-top:14px;font-size:1rem;max-width:36ch}
  .cdetails{margin-top:26px;display:flex;flex-direction:column;gap:13px}
  .cdetail{display:flex;align-items:baseline;gap:12px}
  .cdetail .lbl{font-family:var(--mono);font-size:.66rem;letter-spacing:.12em;text-transform:uppercase;color:var(--teal-bright);width:72px;flex:none}
  .cdetail a,.cdetail span{color:#fff;font-size:.94rem;word-break:break-word}
  .cdetail a:hover{color:var(--teal-bright)}
  .cform{display:flex;flex-direction:column;gap:13px}
  .cform label{display:block;font-family:var(--mono);font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:#9DB2C9;margin-bottom:6px}
  .cform input,.cform textarea{font-family:var(--body);font-size:.95rem;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.18);border-radius:10px;padding:12px 14px;color:#fff;width:100%;transition:border-color .18s}
  .cform input::placeholder,.cform textarea::placeholder{color:#7C90A8}
  .cform input:focus,.cform textarea:focus{outline:none;border-color:var(--teal-bright)}
  .cform textarea{resize:vertical;min-height:104px}
  .btn-teal{background:var(--teal-bright);color:var(--ink);border-color:var(--teal-bright);justify-content:center}
  .btn-teal:hover{filter:brightness(1.06)}
  .btn-on-dark{background:transparent;color:#fff;border-color:rgba(255,255,255,.28)}
  .btn-on-dark:hover{background:#fff;color:var(--ink);border-color:#fff}
  .cf-note{font-family:var(--mono);font-size:.72rem;color:#7C90A8;min-height:1em}
  .cform button:disabled{opacity:.65;cursor:default}

  footer{padding:34px 0 46px;text-align:center;color:var(--muted);font-size:.84rem}
  footer .mono{font-family:var(--mono);font-size:.78rem}

  .reveal{opacity:0;transform:translateY(16px);transition:opacity .6s ease,transform .6s ease}
  .reveal.in{opacity:1;transform:none}

  @media (max-width:820px){
    .hero-grid{grid-template-columns:1fr;gap:34px}
    .exp-grid,.grid2,.contact,.screen-card{grid-template-columns:1fr}
    .contact{gap:30px;padding:36px 26px}
    .nav-links{position:absolute;top:64px;left:0;right:0;background:#fff;flex-direction:column;gap:0;padding:8px 0;border-bottom:1px solid var(--line);display:none}
    .nav-links.open{display:flex}
    .nav-links a{padding:13px 28px}
    .nav-toggle{display:block}
  }
  @media (prefers-reduced-motion:reduce){
    *{animation:none!important;transition:none!important;scroll-behavior:auto!important}
    .reveal{opacity:1;transform:none}
  }

  /* PROFILE TABS */
  .tabs{display:flex;flex-wrap:wrap;gap:4px;margin:16px 0 32px;border-bottom:1px solid var(--line)}
  .tab{font-family:var(--mono);font-size:.84rem;letter-spacing:.03em;color:var(--muted);background:none;border:0;padding:11px 16px;margin-bottom:-1px;cursor:pointer;position:relative;transition:color .18s}
  .tab:hover{color:var(--ink)}
  .tab.is-active{color:var(--ink);font-weight:500}
  .tab.is-active::after{content:"";position:absolute;left:14px;right:14px;bottom:0;height:2px;background:var(--teal);border-radius:2px}
  .tab:focus-visible{outline:2px solid var(--teal-bright);outline-offset:3px;border-radius:6px}
  .tab-panel{display:none}
  .tab-panel.is-active{display:block;animation:fadeTab .35s ease}
  @keyframes fadeTab{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  .tab-panel>h2{font-family:var(--display);font-weight:600;letter-spacing:-.01em;font-size:clamp(1.6rem,3.4vw,2.15rem);color:var(--ink);line-height:1.12;margin-bottom:26px;max-width:62ch}
  /* SECURITY: off-screen honeypot — invisible to humans, tempting to bots */
  .cf-hp{position:absolute!important;left:-9999px!important;top:auto;width:1px;height:1px;overflow:hidden}
  /* VIBE CODING SERIES */
  .post-card{display:block;border:1px solid var(--line);border-radius:16px;padding:26px 28px;background:var(--mist);max-width:640px;transition:border-color .18s,transform .18s,box-shadow .18s}
  .post-card:hover{border-color:var(--teal);transform:translateY(-2px);box-shadow:0 18px 40px -24px rgba(11,31,56,.4)}
  .pc-top{display:flex;gap:8px;align-items:center;margin-bottom:14px}
  .pc-badge{font-family:var(--mono);font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:#fff;background:var(--ink);border-radius:6px;padding:4px 9px}
  .pc-tag{font-family:var(--mono);font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal);background:#fff;border:1px solid var(--line);border-radius:6px;padding:4px 9px}
  .post-card h3{font-family:var(--display);font-weight:600;font-size:1.4rem;color:var(--ink);margin-bottom:8px}
  .post-card p{font-size:.98rem;color:var(--text);margin-bottom:16px;max-width:54ch}
  .pc-cta{font-family:var(--mono);font-size:.84rem;color:var(--teal);font-weight:500}
  .post-card:hover .pc-cta{color:var(--ink)}
  /* BLOG (in-page views) */
  .serieslist{display:flex;flex-direction:column;gap:14px}
  #postview{display:none}
  #postview.show{display:block;padding-bottom:10px}
  #portfolio.hide{display:none}
  #postview .wrap{max-width:900px}
  #postview .crumb{display:inline-block;font-family:var(--mono);font-size:.8rem;color:var(--muted);margin-bottom:18px;transition:color .18s}
  #postview .crumb:hover{color:var(--ink)}
  #postview .crumb::before{content:"\2190  "}
  #postview header.post{padding:54px 0 30px;border-bottom:1px solid var(--line)}
  #postview header.post h1{font-family:var(--display);font-weight:700;letter-spacing:-.02em;font-size:clamp(2rem,5vw,2.9rem);line-height:1.08;color:var(--ink);margin:14px 0 16px}
  #postview .dek{font-size:1.18rem;color:var(--muted);max-width:46ch}
  #postview .meta{margin-top:24px;font-family:var(--mono);font-size:.78rem;letter-spacing:.03em;color:var(--muted);display:flex;flex-wrap:wrap;gap:8px 14px;align-items:center}
  #postview .meta .sep{width:4px;height:4px;border-radius:50%;background:var(--line)}
  #postview article{padding:34px 0 10px}
  #postview article p{font-size:1.08rem;color:var(--text);margin:0 0 20px}
  #postview article p.lead{font-size:1.16rem}
  .pull{font-family:var(--display);font-weight:600;font-size:1.32rem;line-height:1.3;color:var(--ink);border-left:3px solid var(--teal);padding:6px 0 6px 20px;margin:30px 0}
  .layers{display:flex;flex-direction:column;gap:14px;margin:26px 0 8px}
  .lcard{border:1px solid var(--line);border-radius:14px;padding:22px 24px;background:var(--mist)}
  .lcard .lnum{font-family:var(--mono);font-size:.74rem;letter-spacing:.12em;color:var(--teal);font-weight:500}
  .lcard h3{font-family:var(--display);font-weight:600;font-size:1.16rem;color:var(--ink);margin:4px 0 8px}
  .lcard p{font-size:1rem;margin:0;color:var(--text)}
  .lcard .limit{margin-top:10px;font-family:var(--mono);font-size:.84rem;color:var(--muted)}
  .lcard .limit b{color:var(--teal);font-weight:500}
  .bonus{margin:26px 0 8px;border:1px solid var(--line);border-radius:14px;background:var(--mist);overflow:hidden}
  .bonus[open]{border-color:var(--teal)}
  .bonus>summary{list-style:none;cursor:pointer;display:flex;align-items:center;gap:12px;padding:18px 22px;user-select:none;transition:background .18s}
  .bonus>summary::-webkit-details-marker{display:none}
  .bonus>summary:hover{background:#fff}
  .bonus>summary:focus-visible{outline:2px solid var(--teal-bright);outline-offset:-2px}
